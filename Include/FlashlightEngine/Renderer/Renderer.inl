#pragma once

namespace FlashlightEngine {
    inline void Renderer::SetClearColor(const Float32 r, const Float32 g, const Float32 b, const Float32 a) {
        m_ClearColor[0] = r;
        m_ClearColor[1] = g;
        m_ClearColor[2] = b;
        m_ClearColor[3] = a;
    }
}
